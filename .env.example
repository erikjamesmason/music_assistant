# Anthropic API Key (Server-side only - set in Vercel dashboard)
# Get your API key from: https://console.anthropic.com/
#
# IMPORTANT: Set this in your Vercel project settings:
# Project Settings > Environment Variables > Add Variable
# Name: ANTHROPIC_API_KEY
# Value: sk-ant-api03-...
#
# This key is kept secure server-side in the /api/chat serverless function.
# Do NOT use VITE_ANTHROPIC_API_KEY (that would expose it in the browser).

ANTHROPIC_API_KEY=sk-ant-api03-your_api_key_here
